{
  "name": "@etest/db",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "baseline": "tsx ./scripts/baseline.ts",
    "generate": "drizzle-kit generate --config=drizzle.config.ts",
    "lint": "node --eval \"console.log('packages/db lint is intentionally deferred until repo-wide lint rules land.')\"",
    "migrate": "tsx ./scripts/migrate.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.1",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}
